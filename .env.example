# Server-only secrets (never prefix with VITE_)
ADMIN_PASSWORD=change-me
JWT_SECRET=long-random-string

# Optional: Render PostgreSQL connection string. If omitted, campaign is stored in
# server/data/campaign.json (fine for local dev only — not for production).
# DATABASE_URL=postgresql://...

# Local Postgres without SSL:
# PGSSLMODE=disable

# Optional: custom path for file-backed storage (no DATABASE_URL)
# CAMPAIGN_FILE=./server/data/campaign.json

# Uploaded profile images when DATABASE_URL is unset (file-backed campaign only).
# Default: server/uploads. With DATABASE_URL, uploads are stored in Postgres (uploaded_images).
# On PaaS without Postgres, mount a disk if you use local uploads:
# UPLOADS_DIR=/data/corkboard-uploads
